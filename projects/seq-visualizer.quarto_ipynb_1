        "#| echo: false\n",
        "\n",
        "import plotly.graph_objects as go\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "\n",
        "np.random.seed(42)\n",
        "\n",
        "# Generate data\n",
        "genes = [f\"Gene{i}\" for i in range(1, 101)]\n",
        "\n",
        "log2fc = np.concatenate([\n",
        "    np.random.normal(0, 0.5, size=70),\n",
        "    np.random.uniform(-3, 3, size=30)\n",
        "])\n",
        "\n",
        "pvalues = np.concatenate([\n",
        "    np.random.uniform(0.05, 0.5, size=70),\n",
        "    np.random.uniform(0.0001, 0.05, size=30)\n",
        "])\n",
        "\n",
        "neg_log10_pval = -np.log10(pvalues)\n",
        "\n",
        "df = pd.DataFrame({\n",
        "    \"gene\": genes,\n",
        "    \"log2fc\": log2fc,\n",
        "    \"pvalue\": pvalues,\n",
        "    \"neg_log10_pval\": neg_log10_pval\n",
        "})\n",
        "\n",
        "# Threshold\n",
        "p_thresh = 0.05\n",
        "\n",
        "significant = df[\"pvalue\"] < p_thresh\n",
        "\n",
        "fig = go.Figure()\n",
        "\n",
        "# Significant points\n",
        "fig.add_trace(go.Scatter(\n",
        "    x=df.loc[significant, \"log2fc\"],\n",
        "    y=df.loc[significant, \"neg_log10_pval\"],\n",
        "    mode='markers',\n",
        "    marker=dict(color='red', size=8),\n",
        "    name='Significant (p < 0.05)',\n",
        "    text=df.loc[significant, \"gene\"],\n",
        "    hovertemplate=\"Gene: %{text}<br>log2FC: %{x:.2f}<br>-log10(p): %{y:.2f}<extra></extra>\"\n",
        "))\n",
        "\n",
        "# Non-significant points\n",
        "fig.add_trace(go.Scatter(\n",
        "    x=df.loc[~significant, \"log2fc\"],\n",
        "    y=df.loc[~significant, \"neg_log10_pval\"],\n",
        "    mode='markers',\n",
        "    marker=dict(color='lightgray', size=6),\n",
        "    name='Not Significant',\n",
        "    text=df.loc[~significant, \"gene\"],\n",
        "    hovertemplate=\"Gene: %{text}<br>log2FC: %{x:.2f}<br>-log10(p): %{y:.2f}<extra></extra>\"\n",
        "))\n",
        "\n",
        "# Add threshold line\n",
        "fig.add_hline(\n",
        "    y=-np.log10(p_thresh),\n",
        "    line_dash=\"dash\",\n",
        "    line_color=\"black\"\n",
        ")\n",
        "\n",
        "fig.update_layout(\n",
        "    title=\"Volcano Plot\",\n",
        "    xaxis_title=\"Log2 Fold Change\",\n",
        "    yaxis_title=\"-Log10(p-value)\",\n",
        "    height=500,\n",
        "    legend_title=\"Gene Classification\"\n",
        ")\n",
        "\n",
        "fig.add_vline(x=1, line_dash=\"dash\", line_color=\"black\")\n",
        "\n",
        "fig.add_vline(x=-1, line_dash=\"dash\", line_color=\"black\")\n",
        "\n",
        "fig"
      ],
