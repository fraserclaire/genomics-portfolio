        "#| echo: false\n",
        "\n",
        "import plotly.graph_objects as go\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "\n",
        "# --- simulate the CSV users would upload ---\n",
        "df = pd.DataFrame({\n",
        "    \"SampleID\": [\"Sample1\", \"Sample2\", \"Sample3\", \"Sample4\", \"Sample5\"],\n",
        "    \"GeneA\": [5.1, 7.4, 3.2, 6.5, 4.1],\n",
        "    \"GeneB\": [2.3, 6.1, 2.1, 7.2, 3.5],\n",
        "    \"GeneC\": [3.5, 5.9, 4.7, 5.8, 4.8],\n",
        "    \"GeneD\": [4.8, 7.3, 3.9, 6.9, 5.2],\n",
        "    \"GeneE\": [3.2, 6.8, 4.5, 6.4, 4.7]\n",
        "})\n",
        "\n",
        "# Set SampleID as row labels and drop it from matrix\n",
        "df_matrix = df.set_index(\"SampleID\")\n",
        "\n",
        "# Create heatmap\n",
        "fig = go.Figure(\n",
        "    data=go.Heatmap(\n",
        "        z=df_matrix.values,\n",
        "        x=df_matrix.columns,   # Genes\n",
        "        y=df_matrix.index,     # Samples\n",
        "        colorscale=\"Viridis\",\n",
        "        colorbar=dict(title=\"Expression\"),\n",
        "        hovertemplate=\n",
        "            \"Sample: %{y}<br>\" +\n",
        "            \"Gene: %{x}<br>\" +\n",
        "            \"Expression: %{z:.2f}<extra></extra>\"\n",
        "    )\n",
        ")\n",
        "\n",
        "fig.update_layout(\n",
        "    height=500\n",
        ")\n",
        "\n",
        "fig"
      ],
