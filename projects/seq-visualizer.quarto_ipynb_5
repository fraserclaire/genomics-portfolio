    "    \"GeneE\": [3.2, 6.8, 4.5, 6.4, 4.7]\n",
    "})\n",
    "\n",
    "# Set SampleID as row labels and drop it from matrix\n",
    "df_matrix = df.set_index(\"SampleID\")\n",
    "\n",
    "# Create heatmap\n",
    "fig = go.Figure(\n",
    "    data=go.Heatmap(\n",
    "        z=df_matrix.values,\n",
    "        x=df_matrix.columns,   # Genes\n",
