    "import plotly.graph_objects as go\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "# --- simulate the CSV users would upload ---\n",
    "df = pd.DataFrame({\n",
    "    \"SampleID\": [\"Sample1\", \"Sample2\", \"Sample3\", \"Sample4\", \"Sample5\"],\n",
    "    \"GeneA\": [5.1, 7.4, 3.2, 6.5, 4.1],\n",
    "    \"GeneB\": [2.3, 6.1, 2.1, 7.2, 3.5],\n",
