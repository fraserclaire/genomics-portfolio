    "#| echo: false\n",
    "\n",
    "import plotly.graph_objects as go\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "\n",
    "np.random.seed(42)\n",
    "\n",
    "# Generate data\n",
    "genes = [f\"Gene{i}\" for i in range(1, 101)]\n",
    "\n",
    "log2fc = np.concatenate([\n",
    "    np.random.normal(0, 0.5, size=70),\n",
    "    np.random.uniform(-3, 3, size=30)\n",
    "])\n",
    "\n",
    "pvalues = np.concatenate([\n",
    "    np.random.uniform(0.05, 0.5, size=70),\n",
    "    np.random.uniform(0.0001, 0.05, size=30)\n",
    "])\n",
    "\n",
    "neg_log10_pval = -np.log10(pvalues)\n",
    "\n",
    "df = pd.DataFrame({\n",
    "    \"gene\": genes,\n",
    "    \"log2fc\": log2fc,\n",
    "    \"pvalue\": pvalues,\n",
    "    \"neg_log10_pval\": neg_log10_pval\n",
    "})\n",
    "\n",
    "# Threshold\n",
    "p_thresh = 0.05\n",
    "fc_thresh = 1\n",
    "\n",
    "up = (df[\"log2fc\"] > fc_thresh) & (df[\"pvalue\"] < p_thresh)\n",
    "down = (df[\"log2fc\"] < -fc_thresh) & (df[\"pvalue\"] < p_thresh)\n",
    "background = ~(up | down)\n",
    "\n",
    "fig = go.Figure()\n",
    "\n",
    "# Upregulated (red)\n",
    "fig.add_trace(go.Scatter(\n",
    "    x=df.loc[up, \"log2fc\"],\n",
    "    y=df.loc[up, \"neg_log10_pval\"],\n",
    "    mode='markers',\n",
    "    marker=dict(color='red', size=8),\n",
    "    name='Upregulated',\n",
    "    text=df.loc[up, \"gene\"],\n",
    "    hovertemplate=\"Gene: %{text}<br>log2FC: %{x:.2f}<br>-log10(p): %{y:.2f}<extra></extra>\"\n",
    "))\n",
    "\n",
    "# Downregulated (blue)\n",
    "fig.add_trace(go.Scatter(\n",
    "    x=df.loc[down, \"log2fc\"],\n",
    "    y=df.loc[down, \"neg_log10_pval\"],\n",
    "    mode='markers',\n",
    "    marker=dict(color='blue', size=8),\n",
    "    name='Downregulated',\n",
    "    text=df.loc[down, \"gene\"],\n",
    "    hovertemplate=\"Gene: %{text}<br>log2FC: %{x:.2f}<br>-log10(p): %{y:.2f}<extra></extra>\"\n",
    "))\n",
    "\n",
    "# Background (gray)\n",
    "fig.add_trace(go.Scatter(\n",
    "    x=df.loc[background, \"log2fc\"],\n",
    "    y=df.loc[background, \"neg_log10_pval\"],\n",
    "    mode='markers',\n",
    "    marker=dict(color='lightgray', size=5),\n",
    "    name='Not significant',\n",
    "    text=df.loc[background, \"gene\"],\n",
    "    hovertemplate=\"Gene: %{text}<br>log2FC: %{x:.2f}<br>-log10(p): %{y:.2f}<extra></extra>\"\n",
    "))\n",
    "\n",
    "# Add threshold lines\n",
    "fig.add_hline(y=-np.log10(p_thresh),line_dash=\"solid\", line_color=\"blue\")\n",
    "fig.add_vline(x=1, line_dash=\"dash\", line_color=\"black\")\n",
    "fig.add_vline(x=-1, line_dash=\"dash\", line_color=\"black\")\n",
    "\n",
    "fig.update_layout(\n",
    "    xaxis_title=\"Log2 Fold Change\",\n",
    "    yaxis_title=\"-Log10(p-value)\",\n",
    "    height=500,\n",
    "    legend_title=\"Gene Classification\"\n",
    ")\n",
    "\n",
    "# Label top up- and down-regulated genes\n",
    "top_n = 5\n",
    "\n",
    "top_up = df.loc[up].nlargest(top_n, \"neg_log10_pval\")\n",
    "top_down = df.loc[down].nlargest(top_n, \"neg_log10_pval\")\n",
    "\n",
    "top_genes = pd.concat([top_up, top_down])\n",
    "\n",
    "fig.add_trace(go.Scatter(\n",
    "    x=top_genes[\"log2fc\"],\n",
    "    y=top_genes[\"neg_log10_pval\"],\n",
    "    mode=\"text\",\n",
    "    text=top_genes[\"gene\"],\n",
    "    textposition=\"top center\",\n",
    "    showlegend=False\n",
    "))\n",
    "\n",
    "fig"
   ]
